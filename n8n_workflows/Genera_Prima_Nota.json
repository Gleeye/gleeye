                }
            }
        },
        {
            "parameters": {
                "service": "postgres",
                "operation": "executeQuery",
                "query": "select * from get_monthly_bank_statements($1, $2);",
                "additionalFields": {
                    "queryParams": "={{$node[\"Calculate Dates\"].json[\"year\"]}},{{$node[\"Calculate Dates\"].json[\"month\"]}}"
                }
            },
            "name": "Supabase - Get Bank Statements",
            "type": "n8n-nodes-base.supabase",
            "typeVersion": 1,
            "position": [
                1000,
                750
            ],
            "id": "supabase-statements",
            "credentials": {
                "supabaseApi": {
                    "id": "YOUR_SUPABASE_CREDENTIAL_ID"
                }
            }
        },
        {
            "parameters": {
                "url": "={{$json.attachment_url}}",
                "responseFormat": "file",
                "options": {}
            },
            "name": "HTTP Request - Download PDF",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                1250,
                750
            ],
            "id": "download-pdf"
        },
        {
            "parameters": {
                "name": "={{$node[\"Supabase - Get Bank Statements\"].json[\"attachment_name\"]}}",
                "fileContent": "={{$node[\"HTTP Request - Download PDF\"].binary.data}}",
                "parents": [
                    "={{$node[\"GDrive - Create Folder\"].json[\"id\"]}}"
                ]
            },
            "name": "GDrive - Upload PDF",
            "type": "n8n-nodes-base.googleDrive",
            "typeVersion": 2,
            "position": [
                1500,
                750
            ],
            "id": "upload-pdf",
            "credentials": {
                "googleDriveOAuth2Api": {
                    "id": "YOUR_GDRIVE_CREDENTIAL_ID"
                }
            }
        }
    ],
